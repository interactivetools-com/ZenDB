{
  "name": "itools/zendb",
  "description": "PHP/MySQL Database Library with Injection-Proof SQL and Automatic HTML-Encoding",
  "keywords": ["database", "mysql", "mysqli", "sql", "injection", "secure", "html-encoding", "xss", "security", "orm", "db"],
  "type": "library",
  "homepage": "https://github.com/interactivetools-com/ZenDB",
  "license": "MIT",
  "config": {
    "platform": {"php": "8.1.0"}
  },
  "support": {
    "issues": "https://github.com/interactivetools-com/ZenDB/issues",
    "source": "https://github.com/interactivetools-com/ZenDB"
  },
  "authors": [
    {
      "name": "interactivetools.com",
      "homepage": "https://interactivetools.com/"
    }
  ],
  "repositories": [
    {"type": "path", "url": "../SmartArray",  "options": {"symlink": true}, "canonical": false},
    {"type": "path", "url": "../SmartString", "options": {"symlink": true}, "canonical": false}
  ],
  "autoload": {
    "psr-4": {
      "Itools\\ZenDB\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Itools\\ZenDB\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.1",
    "ext-mysqli": "*",
    "itools/smartarray": "^2.5.0",
    "itools/smartstring": "^2.5.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.12"
  },
  "suggest": {
    "ext-mbstring": "For proper UTF-8 handling"
  }
}
