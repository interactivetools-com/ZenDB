{
  "name": "itools/zendb",
  "description": "Injection-proof PHP/MySQL database layer with automatic XSS-safe output",
  "keywords": ["database", "mysql", "mysqli", "sql", "dbal", "crud", "secure", "parameterized-queries", "injection-proof", "database-layer"],
  "type": "library",
  "homepage": "https://github.com/interactivetools-com/ZenDB",
  "license": "MIT",
  "config": {
    "platform": {"php": "8.1.0"}
  },
  "support": {
    "issues": "https://github.com/interactivetools-com/ZenDB/issues",
    "source": "https://github.com/interactivetools-com/ZenDB"
  },
  "authors": [
    {
      "name": "interactivetools.com",
      "homepage": "https://interactivetools.com/"
    }
  ],
  "autoload": {
    "psr-4": {
      "Itools\\ZenDB\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Itools\\ZenDB\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.1",
    "ext-mysqli": "*",
    "ext-openssl": "*",
    "itools/smartarray": "^2.6.6",
    "itools/smartstring": "^2.6.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  }
}
